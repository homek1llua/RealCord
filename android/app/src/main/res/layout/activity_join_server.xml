<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Join Server"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enter an invite code"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/invite_code_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_edit_text"
        android:gravity="center"
        android:hint="INVITE CODE"
        android:maxLength="8"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/join_server_btn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/btn_primary"
        android:text="Join"
        android:textColor="@color/white" />

    <ProgressBar
        android:id="@+id/join_server_progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
